{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["nodejs"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "services": [
      {
        "id": "web",
        "source": ".",
        "definition": {
          "name": "web",
          "run": "node server.js"
        }
      }
    ]
  }
}
